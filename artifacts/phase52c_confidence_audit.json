  "part_e_rebuild_designs": {
    "design_A_statistical": {
      "formula": "conf = w1*DQ + w2*team_margin + w3*range_margin + w4*survival_range_margin",
      "expected_distribution": "Spread 0.35-0.85 if margins vary; uncapped",
      "strengths": "Directly ties confidence to model separation",
      "weaknesses": "Margins small in abstain-heavy cohort; needs per-market scores"
    },
    "design_B_historical_reliability": {
      "formula": "conf = shrinkage_mean(team_backtest_hit, league_hit, bucket_hit | DQ band)",
      "expected_distribution": "Clustered by team/league priors, not single cap",
      "strengths": "Empirically grounded; monotonic if fit on hold-out",
      "weaknesses": "Cold-start teams; needs ongoing eval pipeline"
    },
    "design_C_hybrid": {
      "formula": "conf_team, conf_range, conf_minute separately; display = tier(map(max market conf))",
      "expected_distribution": "3 scores 0.2-0.8; UI shows tier not raw %",
      "strengths": "Fixes single-scalar conflation; supports premium gating per market",
      "weaknesses": "More complex UI/API; requires shadow validation per market"
    }
  },
