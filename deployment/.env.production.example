# Copy to /opt/worldcup-predictor/.env.production on the server.
# Never commit real secrets to git.

APP_ENV=production

# PostgreSQL (required — SaaS auth, users, subscriptions)
DATABASE_URL=postgresql://worldcup_user:CHANGE_ME_STRONG@127.0.0.1:5432/worldcup_predictor

# JWT (required — generate: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET=CHANGE_ME_GENERATE_48_CHAR_RANDOM_SECRET
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Registration gate + admin bootstrap
PUBLIC_ACCESS_ENABLED=true
PUBLIC_ACCESS_CODE=CHANGE_ME_INVITE_CODE
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# Primary match data (required for Match Center + predictions)
API_FOOTBALL_KEY=your_api_football_key
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Optional enrichment (leave empty if unused)
SPORTMONKS_API_TOKEN=
OPENAI_API_KEY=

# CORS — set your public site origin(s), comma-separated (same-origin via Nginx usually needs none)
# CORS_ALLOWED_ORIGINS=https://predictor.example.com

# Intelligence SQLite (prediction engine local cache — path on server)
SQLITE_PATH=data/football_intelligence.db
API_CACHE_DIR=.cache/api_football

# Locale
DEFAULT_LOCALE=en
