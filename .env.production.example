# Copy to .env.production on the Hetzner server — never commit real secrets.

# --- API keys (required for live data) ---
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Default GUI language: en | de | fa | sr | bs | hr ---
DEFAULT_LOCALE=en

# --- Optional enrichment providers ---
WEATHER_PROVIDER=weatherapi
WEATHER_API_KEY=
OPENWEATHER_API_KEY=
SPORTMONKS_API_KEY=
THE_ODDS_API_KEY=

# --- Cache ---
API_CACHE_DIR=.cache/api_football
API_CACHE_TTL_SECONDS=3600

# --- GUI password protection (recommended on public servers) ---
APP_AUTH_ENABLED=true
APP_USERNAME=admin
APP_PASSWORD=change_me_to_a_strong_password

# --- Streamlit / proxy hints ---
# When behind Nginx with HTTPS, set in Nginx or systemd Environment:
# STREAMLIT_SERVER_ENABLECORS=false
# STREAMLIT_SERVER_ENABLEXSRFPROTECTION=true

# --- GUI marketing banner (Phase 33) ---
# Default false — uses real Performance Center winrate when available
SHOW_MARKETING_WINRATE=false
MARKETING_WINRATE_TEXT=Win Rate: 85%+

# --- Official hero banner image (Phase 34) ---
# Default: worldcup_predictor/ui/assets/hero-banner.png
# BANNER_IMAGE_PATH=/path/to/custom-banner.png
